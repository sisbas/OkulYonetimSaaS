{
  "name": "okul-yonetim-saas-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "demo:start": "node scripts/demo-server.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --runInBand src --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "db:migrate:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "db:migrate:show": "typeorm-ts-node-commonjs migration:show -d src/database/data-source.ts",
    "db:seed:permissions": "ts-node src/database/seeds/permissions.seed.ts",
    "db:verify": "ts-node scripts/verify-datasource.ts",
    "test:rbac": "jest --runInBand test/rbac",
    "test:database": "jest --runInBand test/database",
    "test:tenant-guard": "jest --runInBand test/database/tenant-guard.spec.ts test/rbac/tenant-repository-scope.spec.ts",
    "test:kvkk": "jest --runInBand test/kvkk",
    "test:audit-redaction": "jest --runInBand test/kvkk/audit-redaction.spec.ts",
    "ci:sprint1": "bash scripts/ci-quality-gate.sh",
    "demo:full:test": "node --test full-vision-demo/tests/*.test.js",
    "demo:full:build": "node scripts/build-full-vision-demo-static.js",
    "demo:full:http": "node scripts/test-full-vision-demo-static-deployment.js",
    "demo:full:browser": "node full-vision-demo/tests/browser-qa-runner.js",
    "verify:gate2": "npm run demo:full:test && npm run demo:full:build && npm run demo:full:http",
    "demo:hosted:build": "node scripts/build-hosted-demos-static.js",
    "demo:hosted:test": "node scripts/test-hosted-demos-static-deployment.js",
    "verify:hosted-demos": "npm run verify:gate2 && node demo-frontend/smoke-test.js && npm run demo:hosted:test",
    "qa:db": "node -e \"const fs=require('fs'); const dir=process.env.MIGRATIONS_DIR||'src/database/migrations'; if(process.env.REQUIRE_MIGRATIONS==='true'&&!fs.existsSync(dir)){throw new Error('Migration directory missing: '+dir)} const files=fs.existsSync(dir)?fs.readdirSync(dir).filter((file)=>/\\.(ts|js|sql)$/.test(file)).sort():[]; if(process.env.REQUIRE_MIGRATIONS==='true'&&files.length===0){throw new Error('No migration files found in '+dir)} console.log('Migration directory: '+dir); console.log('Migration files: '+files.join(', '));\" && npm run db:migrate && npm run db:verify && npm run db:seed:permissions && npm run test:tenant-guard && npm run test:database && npm run test:kvkk && echo \"QA DB smoke tests passed\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
