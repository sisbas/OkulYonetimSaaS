# Application
PORT=3000
NODE_ENV=development

# Database (use a non-production database for local migration/seed/verify commands)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/okul_yonetim_saas_dev
# Alternatively configure discrete values instead of DATABASE_URL:
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=okul_yonetim_saas_dev

# Optional: tenant used by permission role seed. The seed creates this tenant when absent.
SEED_TENANT_SLUG=system-seed
SEED_TENANT_NAME=System Seed Tenant

TYPEORM_LOGGING=false
